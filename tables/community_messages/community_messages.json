{
  "name": "community_messages",
  "primary_key_column": "id",
  "enable_rls": false,
  "visibility": "POD",
  "columns": [
    {
      "name": "platform",
      "type": "ENUM",
      "required": true,
      "options": [
        "discord",
        "slack",
        "other"
      ]
    },
    {
      "name": "channel_name",
      "type": "TEXT",
      "required": false,
      "max_length": 255
    },
    {
      "name": "author",
      "type": "TEXT",
      "required": true,
      "max_length": 255
    },
    {
      "name": "content",
      "type": "TEXT",
      "required": true
    },
    {
      "name": "status",
      "type": "ENUM",
      "required": true,
      "default": "new",
      "options": [
        "new",
        "investigating",
        "responded",
        "escalated",
        "ignored"
      ]
    },
    {
      "name": "response_sent",
      "type": "TEXT",
      "required": false
    }
  ]
}