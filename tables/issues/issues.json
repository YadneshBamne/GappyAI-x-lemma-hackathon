{
  "name": "issues",
  "primary_key_column": "id",
  "enable_rls": false,
  "visibility": "POD",
  "columns": [
    {
      "name": "project_id",
      "type": "UUID",
      "required": true,
      "foreign_key": {
        "references": "projects.id"
      }
    },
    {
      "name": "title",
      "type": "TEXT",
      "required": true,
      "max_length": 255
    },
    {
      "name": "description",
      "type": "TEXT",
      "required": false
    },
    {
      "name": "priority",
      "type": "ENUM",
      "required": true,
      "default": "medium",
      "options": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    {
      "name": "status",
      "type": "ENUM",
      "required": true,
      "default": "backlog",
      "options": [
        "backlog",
        "todo",
        "in_progress",
        "in_review",
        "done",
        "cancelled"
      ]
    },
    {
      "name": "assignee_agent_name",
      "type": "TEXT",
      "required": false,
      "max_length": 255
    }
  ]
}