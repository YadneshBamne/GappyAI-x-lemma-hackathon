{
  "name": "roadmap",
  "primary_key_column": "id",
  "enable_rls": false,
  "visibility": "POD",
  "columns": [
    {
      "name": "project_id",
      "type": "UUID",
      "required": true,
      "foreign_key": {
        "references": "projects.id"
      }
    },
    {
      "name": "title",
      "type": "TEXT",
      "required": true,
      "max_length": 255
    },
    {
      "name": "description",
      "type": "TEXT",
      "required": false
    },
    {
      "name": "status",
      "type": "ENUM",
      "required": true,
      "default": "proposed",
      "options": [
        "proposed",
        "planned",
        "in_development",
        "completed",
        "deferred"
      ]
    },
    {
      "name": "quarter",
      "type": "TEXT",
      "required": true,
      "max_length": 50
    },
    {
      "name": "target_date",
      "type": "DATE",
      "required": false
    }
  ]
}