{
  "name": "knowledge-agent",
  "description": "Acts as the RAG database coordinator, answering QA and updating docs.",
  "instruction": {
    "$file": "instruction.md"
  },
  "toolsets": [
    "POD"
  ],
  "visibility": "POD",
  "agent_runtime": {
    "profile_id": "system:lemma",
    "model_name": "deepseek-v4-pro"
  },
  "permissions": {
    "grants": [
      {
        "resource_type": "datastore_table",
        "resource_name": "knowledge_articles",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "documentation",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      }
    ]
  }
}